# Nginx Configuration for kafe.ruslandev.uz
# Store this in /etc/nginx/sites-available/kafe.ruslandev.uz

server {
    listen 80;
    server_name kafe.ruslandev.uz;

    # Redirect all HTTP traffic to HTTPS (if SSL is enabled)
    # return 301 https://$host$request_uri;

    location / {
        proxy_pass http://localhost:3001; # Pointing to frontend Docker container
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api {
        proxy_pass http://localhost:8080; # Pointing to backend Docker container
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # WebSocket Support for real-time order updates
    location /api/ws {
        proxy_pass http://localhost:8080/api/ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}

